{
  "name": "Securly for Chromebooks",
  "short_name": "Securly",
  "version": "3.0.37",
  "description": "Secure and manage your 1:1 Chromebooks with Securly",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "identity",
    "cookies",
    "tabs",
    "browsingData",
    "identity.email",
    "geolocation",
    "idle",
    "downloads",
    "storage",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "declarativeNetRequestFeedback",
    "system.display",
    "alarms",
    "webNavigation",
    "offscreen"
  ],
  "host_permissions": [
    "*://*/",
    "file://*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/*",
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://student.magicschool.ai/*",
        "https://student.schoolai.com/*",
        "https://app.schoolai.com/assistants/*",
        "https://app.briskteaching.com/*",
        "https://notebooklm.google.com/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": [
        "content_ai.min.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*",
        "*://youtube-nocookie.com/*",
        "*://*.youtube-nocookie.com/*",
        "*://youtubeeducation.com/*",
        "*://*.youtubeeducation.com/*"
      ],
      "js": [
        "content.min.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.google.com/maps/*",
        "*://google.com/maps/*"
      ],
      "js": [
        "content2.min.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "*://bing.com/search*",
        "*://www.bing.com/search*",
        "*://search.yahoo.com/search*",
        "*://www.search.yahoo.com/search*",
        "*://youtube.com/*",
        "*://www.youtube.com/*",
        "*://google.com/search*",
        "*://www.google.com/search*",
        "*://google.co.uk/search*",
        "*://www.google.co.uk/search*",
        "*://google.ie/search*",
        "*://www.google.ie/search*",
        "*://google.ca/search*",
        "*://www.google.ca/search*",
        "*://google.com.au/search*",
        "*://www.google.com.au/search*",
        "*://google.co.in/search*",
        "*://www.google.co.in/search*"
      ],
      "js": [
        "content3.min.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "*://meet.google.com/*"
      ],
      "js": [
        "content6.min.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content4.min.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content5.min.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "*://chat.google.com/*"
      ],
      "js": [
        "content10.min.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://*/*"
      ],
      "include_globs": [
        "https://www.google.*/*"
      ],
      "js": [
        "content9.min.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.securly.com/crextn/geoloc.html"
      ],
      "js": [
        "content7.min.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content8.min.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content11.min.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "securly.min.js"
  },
  "key": "MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQDAb9tHNQkaX2R/K5CjzGgei7aQXn4wRkJyL8ZRhje0xjgHRPrK0zPictv4i/G0pIUQjoOpPt7QcgenbwbnJ73rRcNtDP03y69cQt8mIrZssAYcyjxSPYOiOABbWLSFp61YRkzfLbnNg/3brOI5sAXigyvJO7ze7cJFH2S/dmsI3wIDAQAB",
  "oauth2": {
    "client_id": "979354546084.apps.googleusercontent.com",
    "scopes": [
      "email"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*",
        "*.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "storage": {
    "managed_schema": "schema.json"
  },
  "manifest_version": 3,
  "update_url": "https://crextnaut.securly.com/subscribers/defaultfrommanifest@securly.com/update-manifest.xml"
}
